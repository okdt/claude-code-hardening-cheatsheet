// Claude Code Setting Hardening Example
// Customize and copy to ~/.claude/settings.json (remove comments)
// See Claude_Code_Hardening_Cheat_Sheet.md for the rationale behind each rule.
// Sandbox: macOS (Seatbelt), Linux/WSL2 (bubblewrap). WSL1 not supported.
{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.gnupg", "~/.aws", "~/.config/gcloud", "~/.bash_history", "~/.zsh_history"]
    }
  },
  "permissions": {
    // ── allow: skip permission prompts for trusted operations ──
    // Uncomment the rules you need. These are examples.
    // "allow": [
    //   // Test & Build
    //   "Bash(npm test *)",
    //   "Bash(npm run build *)",
    //   "Bash(npm run lint *)",
    //   "Bash(pytest *)",
    //   "Bash(go test *)",
    //   "Bash(cargo test *)",
    //   "Bash(make *)",
    //
    //   // Git (safe read-only operations)
    //   "Bash(git status *)",
    //   "Bash(git log *)",
    //   "Bash(git diff *)",
    //   "Bash(git branch *)",
    //
    //   // MCP read-only (allow reading, deny sending)
    //   "mcp__claude_ai_Slack__slack_list_channels",
    //   "mcp__claude_ai_Slack__slack_get_channel_history",
    //   "mcp__claude_ai_Slack__slack_get_thread_replies",
    //   "mcp__claude_ai_Slack__slack_get_users",
    //   "mcp__claude_ai_Slack__slack_search_messages",
    //   "mcp__claude_ai_Google_Calendar__gcal_list_events",
    //   "mcp__claude_ai_Google_Calendar__gcal_list_calendars",
    //   "mcp__claude_ai_Google_Calendar__gcal_get_event"
    // ],

    // ── ask: always prompt, even if previously approved (HITL checkpoint) ──
    // Uncomment the rules you need. These are examples.
    // "ask": [
    //   "Bash(git commit *)",
    //   "Bash(git push *)",
    //   "Bash(npm install *)",
    //   "Bash(pip install *)",
    //   "Bash(brew install *)",
    //   "Bash(psql *)",
    //   "Bash(mysql *)",
    //   "Bash(mongosh *)",
    //   "Bash(sqlite3 *)"
    // ],

    // ── deny: always block, regardless of context ──
    "deny": [
      // Destructive git operations
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout .)",
      "Bash(git clean -f *)",
      "Bash(git add .)",
      "Bash(git add -A)",

      // Destructive file operations
      "Bash(rm -rf *)",
      "Bash(rm -r *)",

      // Dangerous system operations
      "Bash(chmod 777 *)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      // Privilege escalation
      "Bash(sudo *)",
      "Bash(su *)",

      // Remote code execution via pipe
      "Bash(curl *|*sh)",
      "Bash(wget *|*sh)",

      // macOS only — remove these if you're on Linux/Windows
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(defaults write *)",

      // Remote access
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",

      // Package publishing & deployment
      "Bash(npm publish *)",
      "Bash(yarn publish *)",
      "Bash(pnpm publish *)",
      "Bash(*deploy*)",

      // Infrastructure
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(docker push *)",
      "Bash(aws * --no-cli-pager)",
      "Bash(gcloud * --quiet)",

      // Sensitive file access
      "Read(**/.env)",
      "Read(**/.env.*)",

      // MCP actions (sending)
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_schedule_message"
    ]
  }
}
